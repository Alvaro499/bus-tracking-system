    // BUSINESS RULES
    ADMIN_NOT_ACTIVE,
    INVALID_STATE,
    DUPLICATE_RESOURCE,
    INSUFFICIENT_PERMISSIONS,

    // EXTERNAL SERVICES
    EXTERNAL_SERVICE_ERROR,
    SERVICE_UNAVAILABLE,

    // AUTHENTICATION
    UNAUTHORIZED,
    FORBIDDEN,

    // GENERIC
    EXTERNAL_ERROR,
    INTERNAL_ERROR, BUS_LOCATION_NOT_FOUND,
    
