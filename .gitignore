
.env                    # Credenciales reales (NUNCA commitear)
.env.test               # Credenciales test (NUNCA commitear)
.env.local              # Credenciales locales personales
.env.production         # Credenciales producción

# ============================================================================
# BUILD AND DEPENDENCIES
# ============================================================================
target/                 # Maven build output
build/                  # Gradle build output
*.jar                   # JARs compilados
*.class                 # Bytecode compilado
.gradle/                # Gradle cache

node_modules/           # NPM dependencies (si hay frontend)

# ============================================================================
# IDE AND EDITOR
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store               # macOS
Thumbs.db               # Windows

# ============================================================================
# LOGS AND TEMPORARY FILES
# ============================================================================
*.log
*.out
tmp/
temp/
