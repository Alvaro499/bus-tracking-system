# Environment variables
# Sensitive configuration files that should not be shared in the repository
.env
.env.*
.env.local

# Dependencies
# Installed dependencies directories
node_modules/
pnpm-lock.yaml
yarn.lock

# Build output
# Generated directories during compilation and build
dist/
build/
out/
.next/

# Cache
# Local cache files and directories
.cache/
.parcel-cache/

# OS files
# Files generated by operating systems
.DS_Store
Thumbs.db

# IDE and Editor
# Local development tool configurations
.vscode/
.idea/

# Logs
# Log and debug files
*.log
npm-debug.log*
